                                        <th scope="col" style="padding: 1rem;">비교 지표</th>
                                        <th scope="col" style="padding: 1rem;">노션 네이티브 엔진</th>
                                        <th scope="col" style="padding: 1rem; color: var(--primary-color);">Single Notion 아키텍처</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr style="border-bottom: 1px solid #e2e8f0;">
