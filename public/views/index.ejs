    <%- include('partials/navbar') %>

    <main class="main-content">
        <section class="hero">
            <div class="container fade-in-up">
                <!-- <div class="badge">A4 출력이 추가되었습니다.✨</div> -->
                <h1 class="title">노션 문서를<br><span class="highlight"><span class="typed-text"></span></span></h1>
                <p class="subtitle">단일 페이지부터 표준 규격(A4)까지,<br>링크 하나로 노션 페이지를 가장 깔끔한 PDF로 저장하세요.</p>
                
                <form id="convertForm" class="url-input-wrapper">
                    <div class="input-inner">
                        <i class="fa-solid fa-link input-icon"></i>
                        <input type="text" id="url" name="url" placeholder="노션 페이지 링크" required>
                        <button type="submit" id="submitBtn" class="submit-btn">
                            변환하기 <i class="fa-solid fa-arrow-right"></i>
                        </button>
                    </div>
                </form>
                <p class="helper-text"><i class="fa-solid fa-circle-info"></i> 우측 상단 '공유'에서 <strong>게시(웹에서 게시)</strong> 또는 <strong>링크가 있는 모든 사용자</strong> 상태여야 합니다.</p>
            </div>
        </section>

        <section id="how-it-works" class="features">
            <div class="container">
                <div class="feature-grid">
                    <div class="feature-card fade-in-up" style="animation-delay: 0.1s;">
                        <div class="step-number">01</div>
                        <div class="icon-box"><i class="fa-solid fa-share-nodes"></i></div>
                        <h3>링크 공유 설정</h3>
                        <p>노션 우측 상단의 '공유' 메뉴에서<br>'웹에서 게시' 또는 권한을 활성화하세요.</p>
                    </div>
                    <div class="feature-card fade-in-up" style="animation-delay: 0.2s;">
                        <div class="step-number">02</div>
                        <div class="icon-box"><i class="fa-solid fa-paste"></i></div>
                        <h3>URL 붙여넣기</h3>
                        <p>복사한 노션 페이지의 링크를<br>메인 화면의 입력창에 붙여넣습니다.</p>
                    </div>
                    <div class="feature-card fade-in-up" style="animation-delay: 0.3s;">
                        <div class="step-number">03</div>
                        <div class="icon-box"><i class="fa-solid fa-sliders"></i></div>
                        <h3>옵션 조절 및 저장</h3>
                        <p>단일 페이지 또는 표준 규격을 선택하고<br>PDF로 다운로드하세요.</p>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <%- include('partials/footer') %>


    <script>
        // Typed.js 초기화 - 한 번만 실행되도록 loop 옵션 변경
        var typed = new Typed('.typed-text', {
            strings: ['보이는 그대로', '가장 노션답게', 'PDF로 변환하기'],
            typeSpeed: 60,
            backSpeed: 30,
            loop: false, // 이 부분을 false로 변경
            backDelay: 2000
        });

        document.getElementById('convertForm').addEventListener('submit', function(e) {
            e.preventDefault();
            
            const formData = new FormData(this);
            let rawUrl = formData.get('url').trim();

            try {
                const urlObj = new URL(rawUrl);
                rawUrl = `${urlObj.origin}${urlObj.pathname}`;
            } catch (e) {
                alert('올바른 URL 형식이 아닙니다.');
                return;
            }

            const params = new URLSearchParams({
                url: rawUrl
            });

            window.location.href = `standard-edit.html?${params.toString()}`;
        });
    </script>
</body>
</html>