{
  "manifest_version": 3,
  "name": "Single Notion",
  "version": "0.1.0",
  "description": "Capture Notion page content and convert to PDF directly from your browser",
  "permissions": [
  ],
  "host_permissions": [
    "https://*.notion.so/*",
    "https://*.notion.site/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Single Notion"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.notion.so/*",
        "https://*.notion.site/*",
        "https://notion.so/*",
        "https://notion.site/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
